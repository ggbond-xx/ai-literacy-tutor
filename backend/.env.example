APP_NAME=AI Literacy Tutor API
APP_VERSION=0.1.0
API_PREFIX=/api
SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=ai_literacy_tutor
# Optional: set DATABASE_URL to force a specific database backend.
# Example for local fallback: DATABASE_URL=sqlite:///E:/知识图谱/ai-literacy-tutor/backend/dev_fallback.db

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
